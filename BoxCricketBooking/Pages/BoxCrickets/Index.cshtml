@page
@model BoxCricketBooking.Pages.BoxCrickets.IndexModel
@{
    ViewData["Title"] = "Available Cricket Boxes";
}

<div class="container py-5">
    <div class="row mb-4">
        <div class="col-12">
            <h1 class="display-4 fw-bold text-center mb-3">Available Cricket Boxes</h1>
            <p class="lead text-center text-muted">Choose your perfect cricket box and book your slot today!</p>
        </div>
    </div>

    <div class="row g-4">
        @foreach (var boxCricket in Model.BoxCrickets)
        {
            <div class="col-lg-4 col-md-6">
                <div class="card h-100 shadow-sm">
                    @if (!string.IsNullOrEmpty(boxCricket.ImageUrl))
                    {
                        <img src="@boxCricket.ImageUrl" class="card-img-top" alt="@boxCricket.Name" style="height: 200px; object-fit: cover;">
                    }
                    else
                    {
                        <div class="card-img-top bg-light d-flex align-items-center justify-content-center" style="height: 200px;">
                            <i class="fas fa-cricket-bat fa-3x text-muted"></i>
                        </div>
                    }
                    
                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title">@boxCricket.Name</h5>
                        <p class="card-text text-muted">@boxCricket.Description</p>
                        
                        <div class="mt-auto">
                            <div class="row mb-3">
                                <div class="col-6">
                                    <small class="text-muted">Price per hour:</small>
                                    <div class="fw-bold text-primary">₹@boxCricket.PricePerHour</div>
                                </div>
                                <div class="col-6">
                                    <small class="text-muted">Max players:</small>
                                    <div class="fw-bold">@boxCricket.MaxPlayers</div>
                                </div>
                            </div>
                            
                            <div class="mb-3">
                                <small class="text-muted">Location:</small>
                                <div class="fw-bold">@boxCricket.Location</div>
                            </div>
                            
                            <div class="d-grid gap-2">
                                @if (boxCricket.IsAvailable)
                                {
                                    <a href="/Bookings/Create?boxId=@boxCricket.Id" class="btn btn-primary">
                                        <i class="fas fa-calendar-plus me-2"></i>Book Now
                                    </a>
                                }
                                else
                                {
                                    <button class="btn btn-secondary" disabled>
                                        <i class="fas fa-times me-2"></i>Not Available
                                    </button>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>

    @if (!Model.BoxCrickets.Any())
    {
        <div class="text-center py-5">
            <i class="fas fa-cricket-bat fa-4x text-muted mb-3"></i>
            <h3>No cricket boxes available at the moment</h3>
            <p class="text-muted">Please check back later or contact us for more information.</p>
        </div>
    }
</div>

<style>
.card {
    border: none;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
}

.card:hover {
    transform: translateY(-5px);
    box-shadow: 0 8px 25px rgba(0, 0, 0, 0.15) !important;
}

.card-img-top {
    border-top-left-radius: 0.375rem;
    border-top-right-radius: 0.375rem;
}
</style>