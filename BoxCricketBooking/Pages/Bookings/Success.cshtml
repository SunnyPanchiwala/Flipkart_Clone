@page
@model BoxCricketBooking.Pages.Bookings.SuccessModel
@{
    ViewData["Title"] = "Booking Confirmed";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow border-success">
                <div class="card-header bg-success text-white text-center">
                    <i class="fas fa-check-circle fa-3x mb-3"></i>
                    <h2 class="mb-0">Booking Confirmed!</h2>
                </div>
                <div class="card-body text-center">
                    @if (Model.Booking != null)
                    {
                        <div class="alert alert-success">
                            <h4 class="alert-heading">Payment Successful!</h4>
                            <p>Your cricket match has been successfully booked. We've sent a confirmation email to <strong>@Model.Booking.CustomerEmail</strong></p>
                        </div>

                        <div class="row mb-4">
                            <div class="col-md-6">
                                <div class="card bg-light">
                                    <div class="card-body">
                                        <h5 class="card-title">Booking Details</h5>
                                        <p class="mb-1"><strong>Booking ID:</strong> #@Model.Booking.Id</p>
                                        <p class="mb-1"><strong>Customer:</strong> @Model.Booking.CustomerName</p>
                                        <p class="mb-1"><strong>Date:</strong> @Model.Booking.BookingDate.ToString("dddd, MMMM dd, yyyy")</p>
                                        <p class="mb-1"><strong>Time:</strong> @Model.Booking.StartTime.ToString("HH:mm") - @Model.Booking.EndTime.ToString("HH:mm")</p>
                                        <p class="mb-0"><strong>Players:</strong> @Model.Booking.NumberOfPlayers</p>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="card bg-light">
                                    <div class="card-body">
                                        <h5 class="card-title">Cricket Box Details</h5>
                                        <p class="mb-1"><strong>Box:</strong> @Model.Booking.BoxCricket?.Name</p>
                                        <p class="mb-1"><strong>Location:</strong> @Model.Booking.BoxCricket?.Location</p>
                                        <p class="mb-1"><strong>Amount Paid:</strong> ₹@Model.Booking.TotalAmount.ToString("N2")</p>
                                        <p class="mb-0"><strong>Status:</strong> <span class="badge bg-success">Confirmed</span></p>
                                    </div>
                                </div>
                            </div>
                        </div>

                        @if (!string.IsNullOrEmpty(Model.Booking.SpecialRequirements))
                        {
                            <div class="alert alert-info">
                                <h5>Special Requirements:</h5>
                                <p class="mb-0">@Model.Booking.SpecialRequirements</p>
                            </div>
                        }

                        <div class="alert alert-warning">
                            <h5><i class="fas fa-info-circle me-2"></i>Important Information</h5>
                            <ul class="text-start mb-0">
                                <li>Please arrive 15 minutes before your scheduled time</li>
                                <li>Bring your own sports shoes (no spikes allowed)</li>
                                <li>Cricket equipment will be provided</li>
                                <li>Water and refreshments are available at the facility</li>
                                <li>For cancellations, please contact us at least 24 hours in advance</li>
                            </ul>
                        </div>

                        <div class="d-grid gap-2 d-md-flex justify-content-md-center">
                            <a href="/" class="btn btn-primary me-md-2">
                                <i class="fas fa-home me-2"></i>Back to Home
                            </a>
                            <a href="/BoxCrickets" class="btn btn-outline-primary me-md-2">
                                <i class="fas fa-calendar-plus me-2"></i>Book Another Match
                            </a>
                            <button onclick="window.print()" class="btn btn-outline-secondary">
                                <i class="fas fa-print me-2"></i>Print Receipt
                            </button>
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-4">
                            <i class="fas fa-exclamation-triangle fa-3x text-warning mb-3"></i>
                            <h4>Booking Not Found</h4>
                            <p class="text-muted">The booking you're looking for doesn't exist.</p>
                            <a href="/BoxCrickets" class="btn btn-primary">
                                <i class="fas fa-home me-2"></i>Go to Home
                            </a>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<style>
@media print {
    .btn, .alert-warning {
        display: none !important;
    }
    
    .card {
        border: none !important;
        box-shadow: none !important;
    }
    
    .card-header {
        background-color: #28a745 !important;
        color: white !important;
    }
}
</style>